g = getgenv()


---[[ Settings ]]---
g.set = {
	reach = {

		toggled = true, -- reach toggle 

		range = 5, -- reach range

		amp = false	-- damage
	},

	lunge = {

		autoLunge = false,

		lungeRange = 7
	}
}
